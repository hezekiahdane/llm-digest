# ─────────────────────────────────────────────────────────────────────────────
# Base System Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required (core) ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My App"
NODE_ENV=development

# ─── Auth module (optional — delete if not using auth) ───────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database module (optional — delete if not using database)
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require
# DATABASE_URL_DIRECT=postgresql://user:pass@host:5432/db?sslmode=require

# ─── Email module (optional — delete if not using email) ─────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=no-reply@yourdomain.com
# RESEND_ADMIN_EMAIL=admin@yourdomain.com

# ─── Security — Arcjet (optional, degrades gracefully) ───────
# ARCJET_KEY=ajkey_xxxxxxxxxxxx

# ─── Monitoring — Sentry (optional, degrades gracefully) ─────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# ─── Build ────────────────────────────────────────────────────
# SKIP_ENV_VALIDATION=true  # Set in CI/CD to skip env validation during build
