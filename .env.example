# ─────────────────────────────────────────────────────────────────────────────
# AI Intelligence Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Required (core) ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="AI Digest Dashboard"
NODE_ENV=development

# ─── Upstash Redis — required for data caching ───────────────
# Vercel auto-injects these when you connect the Upstash store to the project
# Find them in: Vercel → Storage → your Redis store → .env.local tab
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Cron job secret ─────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
CRON_SECRET=

# ─── Security — Arcjet (optional, degrades gracefully) ───────
# ARCJET_KEY=ajkey_xxxxxxxxxxxx

# ─── Monitoring — Sentry (optional, degrades gracefully) ─────
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# ─── Build ────────────────────────────────────────────────────
# SKIP_ENV_VALIDATION=true  # Set in CI/CD to skip env validation during build
